# Orbit Order Hub - Environment Variables
# Copy this file to .env.local and fill in your values

# App URL (used for OAuth redirects)
PUBLIC_APP_URL=http://localhost:3000

# Supabase - Server side (Service role key for admin operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase - Client side (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Google OAuth (for Gmail API access)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Gmail OAuth State Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
GMAIL_OAUTH_STATE_SECRET=your-long-random-secret

# AfterShip Tracking
AFTERSHIP_API_KEY=your-aftership-api-key
AFTERSHIP_WEBHOOK_SECRET=your-aftership-webhook-secret

# Token Encryption Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# Must be a base64-encoded 32-byte key
TOKEN_ENCRYPTION_KEY=your-base64-encoded-32-byte-key